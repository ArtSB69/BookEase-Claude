// BookEase Prisma Schema
// Merchant-first booking platform for Thai service businesses

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Auth (NextAuth compatible)
// ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model OtpCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone])
}

// ─────────────────────────────────────────────
// User (merchant owners / staff)
// ─────────────────────────────────────────────

enum UserRole {
  owner
  admin
  staff
  customer
}

model User {
  id           String    @id @default(cuid())
  name         String?
  email        String?   @unique
  emailVerified DateTime?
  phone        String?   @unique
  image        String?
  passwordHash String?
  role         UserRole  @default(owner)
  merchantId   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  merchant  Merchant? @relation(fields: [merchantId], references: [id])
}

// ─────────────────────────────────────────────
// Merchant
// ─────────────────────────────────────────────

enum BusinessType {
  salon
  clinic
  spa
  barber
  wellness
  beauty
  massage
  nail
  other
}

model Merchant {
  id             String       @id @default(cuid())
  name           String
  slug           String       @unique
  businessType   BusinessType @default(salon)
  phone          String
  email          String?
  address        String?
  description    String?      @db.Text
  logoUrl        String?
  coverImageUrl  String?
  isPublished    Boolean      @default(false)
  platformFee    Float        @default(3.9)
  openTime       String       @default("09:00")
  closeTime      String       @default("20:00")
  workDays       String[]     @default(["MON","TUE","WED","THU","FRI","SAT"])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  users    User[]
  services Service[]
  bookings Booking[]
  assets   ShopAsset[]
}

// ─────────────────────────────────────────────
// Service
// ─────────────────────────────────────────────

model Service {
  id              String   @id @default(cuid())
  merchantId      String
  name            String
  description     String?  @db.Text
  durationMinutes Int      @default(60)
  price           Float
  isActive        Boolean  @default(true)
  category        String?
  sortOrder       Int      @default(0)
  imageUrl        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  merchant Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  bookings Booking[]
}

// ─────────────────────────────────────────────
// Customer
// ─────────────────────────────────────────────

model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String?
  lineId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings Booking[]
}

// ─────────────────────────────────────────────
// Booking
// ─────────────────────────────────────────────

enum BookingStatus {
  pending
  confirmed
  completed
  cancelled
  no_show
}

enum PaymentStatus {
  unpaid
  pending
  paid
  refunded
  failed
}

model Booking {
  id            String        @id @default(cuid())
  merchantId    String
  serviceId     String
  customerId    String
  bookingDate   DateTime      @db.Date
  startTime     String
  endTime       String
  status        BookingStatus @default(pending)
  note          String?       @db.Text
  paymentStatus PaymentStatus @default(unpaid)
  paymentAmount Float?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  merchant  Merchant  @relation(fields: [merchantId], references: [id])
  service   Service   @relation(fields: [serviceId], references: [id])
  customer  Customer  @relation(fields: [customerId], references: [id])
  payments  Payment[]
}

// ─────────────────────────────────────────────
// Payment
// ─────────────────────────────────────────────

model Payment {
  id                     String        @id @default(cuid())
  bookingId              String
  merchantId             String
  amount                 Float
  platformFeeAmount      Float         @default(0)
  paymentGatewayFeeAmount Float        @default(0)
  status                 PaymentStatus @default(pending)
  paymentMethod          String?
  transactionRef         String?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id])
}

// ─────────────────────────────────────────────
// ShopAsset (QR codes, links)
// ─────────────────────────────────────────────

enum AssetType {
  booking_qr
  admin_qr
  booking_link
  admin_link
}

model ShopAsset {
  id            String    @id @default(cuid())
  merchantId    String
  type          AssetType
  url           String
  qrCodeImageUrl String?
  createdAt     DateTime  @default(now())

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
}
